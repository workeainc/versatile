{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://versatileinterior.com.bd",
          "https://www.versatileinterior.com.bd",
          "http://localhost:3000"
        ],
        "methods": [
          "GET",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "ETag",
        "Cache-Control",
        "Content-Type"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
